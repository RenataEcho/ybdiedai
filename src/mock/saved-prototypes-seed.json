    "html": "<!DOCTYPE html><html lang=\"zh-CN\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no\"><title>绑定导师</title><style>*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}html,body{min-height:100vh}body{background:#f0f2f7;font-family:-apple-system,BlinkMacSystemFont,'PingFang SC','Hiragino Sans GB',sans-serif;padding-bottom:100px}:root{--primary:#FF420C;--primary-end:#ff6a3d;--warn-bg:#fffbeb;--warn-border:#fde68a;--warn-text:#d97706;--ok-bg:#f0fdf4;--ok-border:#bbf7d0;--ok-text:#16a34a;--err-bg:#fef2f2;--err-border:#fecaca;--err-text:#dc2626}.state-bar{position:fixed;top:0;left:0;right:0;z-index:999;display:flex;justify-content:center;gap:5px;padding:8px 12px;flex-wrap:wrap;background:rgba(240,242,247,.92);backdrop-filter:blur(8px);border-bottom:1px solid rgba(0,0,0,.06)}.sw-btn{padding:4px 11px;border-radius:20px;font-size:10px;font-weight:600;border:1.5px solid #cbd5e1;background:#fff;color:#64748b;cursor:pointer;transition:all .18s;line-height:1.5}.sw-btn.active{background:linear-gradient(135deg,var(--primary),var(--primary-end));border-color:transparent;color:#fff;box-shadow:0 2px 8px rgba(255,66,12,.3)}.hero{position:relative;width:100%;height:190px;overflow:hidden;flex-shrink:0;margin-top:49px}.hero-bg{width:100%;height:100%;background:linear-gradient(160deg,#7a1a00 0%,#b52800 35%,#FF420C 70%,#ff6a3d 100%)}.hero-overlay{position:absolute;inset:0;background:radial-gradient(ellipse at 30% 40%,rgba(255,200,150,.3),transparent 55%),radial-gradient(ellipse at 80% 70%,rgba(255,120,60,.25),transparent 50%)}.hero-content{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px}.hero-avatar{width:60px;height:60px;border-radius:50%;background:rgba(255,255,255,.15);border:2px solid rgba(255,255,255,.35);display:flex;align-items:center;justify-content:center;backdrop-filter:blur(8px)}.hero-title{font-size:20px;font-weight:700;color:#fff;letter-spacing:.5px}.hero-sub{font-size:12px;color:rgba(255,255,255,.7);text-align:center;padding:0 24px}.content{padding:16px 16px 0;position:relative;z-index:1;margin-top:-20px}.form-card{background:#fff;border-radius:18px;padding:20px 16px;box-shadow:0 2px 20px rgba(0,0,0,.07);margin-bottom:12px}.sec-label{font-size:10px;font-weight:700;color:#94a3b8;letter-spacing:.1em;text-transform:uppercase;margin-bottom:14px}.field-row{display:flex;flex-direction:column;gap:5px;margin-bottom:14px}.field-row:last-child{margin-bottom:0}.f-label{font-size:13px;font-weight:500;color:#374151;display:flex;align-items:center;gap:3px}.req{color:#ef4444;font-size:11px}.f-input{width:100%;padding:11px 13px;border:1.5px solid #e5e7eb;border-radius:11px;font-size:14px;color:#1e293b;background:#fff;outline:none;transition:border-color .2s;-webkit-appearance:none}.f-input:focus{border-color:#FF420C;box-shadow:0 0 0 3px rgba(255,66,12,.1)}.f-input::placeholder{color:#cbd5e1}.f-hint{font-size:10px;color:#94a3b8;line-height:1.4}.divider{height:1px;background:#f1f5f9;margin:4px 0 16px}.status-banner{border-radius:12px;padding:12px 14px;display:flex;gap:10px;align-items:flex-start;margin-bottom:14px}.status-banner.warn{background:var(--warn-bg);border:1px solid var(--warn-border)}.status-banner.ok{background:var(--ok-bg);border:1px solid var(--ok-border)}.status-banner.err{background:var(--err-bg);border:1px solid var(--err-border)}.bi{font-size:16px;flex-shrink:0;margin-top:1px}.bt{font-size:12px;font-weight:600;margin-bottom:2px}.bt.warn{color:var(--warn-text)}.bt.ok{color:var(--ok-text)}.bt.err{color:var(--err-text)}.bd{font-size:11px;color:#94a3b8;line-height:1.5}.reject-box{margin-top:10px;padding:11px 13px;background:var(--err-bg);border:1px solid var(--err-border);border-radius:11px}.rl{font-size:10px;font-weight:700;color:var(--err-text);margin-bottom:3px;letter-spacing:.04em;text-transform:uppercase}.rt{font-size:12px;color:#1e293b;line-height:1.6}.footer{position:fixed;bottom:0;left:0;right:0;padding:12px 16px 28px;background:#fff;border-top:1px solid #f1f5f9;z-index:100}.main-btn{width:100%;padding:14px;border-radius:14px;font-size:15px;font-weight:600;cursor:pointer;border:none;outline:none;transition:all .2s;letter-spacing:.4px;-webkit-appearance:none}.main-btn.ready{background:#FF420C;color:#fff;box-shadow:0 4px 14px rgba(255,66,12,.35)}.main-btn.ready:active{transform:scale(.98);background:#e03a0a}.main-btn.reviewing{background:#fffbeb;color:#d97706;border:1.5px solid #fde68a;pointer-events:none}.main-btn.unbind{background:var(--err-bg);color:var(--err-text);border:1.5px solid var(--err-border)}.main-btn.unbind:active{transform:scale(.98)}.main-btn.unbind-reviewing{background:#f1f5f9;color:#94a3b8;border:1.5px solid #e2e8f0;pointer-events:none}.spin-wrap{display:flex;align-items:center;justify-content:center;gap:8px}.spin{width:14px;height:14px;border:2px solid rgba(217,119,6,.25);border-top-color:#d97706;border-radius:50%;animation:sp .8s linear infinite}@keyframes sp{to{transform:rotate(360deg)}}.toast{position:fixed;left:50%;bottom:110px;transform:translateX(-50%) scale(.88);background:rgba(15,23,42,.88);color:#f8fafc;padding:9px 18px;border-radius:10px;font-size:13px;white-space:nowrap;z-index:999;opacity:0;pointer-events:none;transition:all .22s}.toast.show{opacity:1;transform:translateX(-50%) scale(1)}</style></head><body><div class=\"state-bar\"><button class=\"sw-btn active\" onclick=\"switchState('idle')\">待提交</button><button class=\"sw-btn\" onclick=\"switchState('reviewing')\">审核中</button><button class=\"sw-btn\" onclick=\"switchState('approved')\">已通过</button><button class=\"sw-btn\" onclick=\"switchState('rejected')\">已驳回</button><button class=\"sw-btn\" onclick=\"switchState('unbind-reviewing')\">解绑审核中</button><button class=\"sw-btn\" onclick=\"switchState('unbind-rejected')\">解绑驳回</button></div><div class=\"hero\"><div class=\"hero-bg\"><div class=\"hero-overlay\"></div></div><div class=\"hero-content\"><div class=\"hero-avatar\"><svg width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fff\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"/><circle cx=\"9\" cy=\"7\" r=\"4\"/><path d=\"M23 21v-2a4 4 0 0 0-3-3.87\"/><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"/></svg></div><div class=\"hero-title\">绑定导师</div><div id=\"heroSub\" class=\"hero-sub\">填写信息完成导师绑定申请</div></div></div><div class=\"content\"><div class=\"form-card\"><div id=\"statusBanner\"></div><div class=\"sec-label\">导师信息</div><div class=\"field-row\"><div class=\"f-label\">绑定导师</div><input class=\"f-input\" type=\"text\" value=\"王志远 · 高级导师\" id=\"fMentor\" disabled style=\"background:#f8fafc;color:#94a3b8\"></div><div class=\"field-row\"><div class=\"f-label\">导师类型</div><input class=\"f-input\" type=\"text\" value=\"内容创作导师\" disabled style=\"background:#f8fafc;color:#94a3b8\"></div><div class=\"divider\"></div><div class=\"sec-label\">学员信息</div><div class=\"field-row\"><div class=\"f-label\">学员真实姓名 <span class=\"req\">*</span></div><input id=\"realName\" class=\"f-input\" type=\"text\" placeholder=\"请输入真实姓名\"></div><div class=\"field-row\"><div class=\"f-label\">学员星图ID <span class=\"req\">*</span></div><input id=\"xingtuIds\" class=\"f-input\" type=\"text\" placeholder=\"多个ID用逗号分隔\"><div class=\"f-hint\">支持多个星图账号，用英文逗号「,」分隔</div></div><div id=\"rejectBlock\"></div></div></div><div class=\"footer\"><button id=\"mainBtn\" class=\"main-btn ready\" onclick=\"handleMainAction()\">提交绑定</button></div><div id=\"toast\" class=\"toast\"></div><script>var STATES={idle:{sub:'填写信息完成导师绑定申请',banner:null,fieldsDisabled:false,btnCls:'ready',btnText:'提交绑定',reject:null},reviewing:{sub:'申请已提交，等待审核中…',banner:{type:'warn',icon:'⏳',title:'审核中，请耐心等待',desc:'您的绑定申请已提交，通常 1-3 个工作日内完成审核'},fieldsDisabled:true,btnCls:'reviewing',btnText:'spinning',reject:null},approved:{sub:'导师绑定成功 ✨',banner:{type:'ok',icon:'✅',title:'审核已通过',desc:'您已成功绑定导师王志远，可随时申请解绑'},fieldsDisabled:true,btnCls:'unbind',btnText:'申请解绑',reject:null},rejected:{sub:'申请未通过，请修改后重新提交',banner:{type:'err',icon:'❌',title:'审核驳回',desc:'您的绑定申请被驳回，请查看驳回原因并重新提交'},fieldsDisabled:false,btnCls:'ready',btnText:'重新提交',reject:'星图ID格式不正确，请核实后重新填写。如有疑问请联系客服 400-800-0000。'},'unbind-reviewing':{sub:'解绑申请审核中…',banner:{type:'warn',icon:'⏳',title:'解绑审核中',desc:'您的解绑申请已提交，审核通过后将自动解除绑定关系'},fieldsDisabled:true,btnCls:'unbind-reviewing',btnText:'解绑审核中',reject:null},'unbind-rejected':{sub:'解绑申请未通过',banner:{type:'err',icon:'❌',title:'解绑审核驳回',desc:'您的解绑申请被驳回，请查看驳回原因后重新申请'},fieldsDisabled:true,btnCls:'unbind',btnText:'重新申请解绑',reject:'当前存在未完成的课程订单，无法解除绑定。请完成所有订单后再申请解绑。'}};var STATE_KEYS=['idle','reviewing','approved','rejected','unbind-reviewing','unbind-rejected'];var cur='idle';function render(){var c=STATES[cur];document.getElementById('heroSub').textContent=c.sub;var b=document.getElementById('statusBanner');b.innerHTML=c.banner?'<div class=\"status-banner '+c.banner.type+'\"><span class=\"bi\">'+c.banner.icon+'</span><div><div class=\"bt '+c.banner.type+'\">'+c.banner.title+'</div><div class=\"bd\">'+c.banner.desc+'</div></div></div>':'';document.querySelectorAll('#realName,#xingtuIds').forEach(function(el){el.disabled=c.fieldsDisabled;el.style.background=c.fieldsDisabled?'#f8fafc':'#fff';el.style.color=c.fieldsDisabled?'#94a3b8':'#1e293b'});var btn=document.getElementById('mainBtn');btn.className='main-btn '+c.btnCls;btn.innerHTML=c.btnText==='spinning'?'<div class=\"spin-wrap\"><div class=\"spin\"></div><span>审核中，请耐心等待</span></div>':c.btnText;var rb=document.getElementById('rejectBlock');rb.innerHTML=c.reject?'<div class=\"reject-box\"><div class=\"rl\">驳回原因</div><div class=\"rt\">'+c.reject+'</div></div>':''}function switchState(s){cur=s;document.querySelectorAll('.sw-btn').forEach(function(b,i){b.classList.toggle('active',STATE_KEYS[i]===s)});render()}function handleMainAction(){if(cur==='idle'||cur==='rejected'){var n=document.getElementById('realName').value.trim();var x=document.getElementById('xingtuIds').value.trim();if(!n){showToast('请输入学员真实姓名');return}if(!x){showToast('请输入学员星图ID');return}switchState('reviewing');showToast('申请已提交，等待审核')}else if(cur==='approved'||cur==='unbind-rejected'){switchState('unbind-reviewing');showToast('解绑申请已提交')}}function showToast(msg){var t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');clearTimeout(t._t);t._t=setTimeout(function(){t.classList.remove('show')},2200)}render();</script></body></html>",
