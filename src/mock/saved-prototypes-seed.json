tent:center;cursor:pointer}.status-banner{border-radius:12px;padding:12px 14px;display:flex;gap:10px;align-items:flex-start;margin-bottom:14px}.status-banner.warn{background:var(--warn-bg);border:1px solid var(--warn-border)}.status-banner.ok{background:var(--ok-bg);border:1px solid var(--ok-border)}.status-banner.err{background:var(--err-bg);border:1px solid var(--err-border)}.bi{font-size:16px;flex-shrink:0;margin-top:1px}.bt{font-size:12px;font-weight:600;margin-bottom:2px}.bt.warn{color:var(--warn-text)}.bt.ok{color:var(--ok-text)}.bt.err{color:var(--err-text)}.bd{font-size:11px;color:#94a3b8;line-height:1.5}.reject-box{margin-top:10px;padding:11px 13px;background:var(--err-bg);border:1px solid var(--err-border);border-radius:11px}.rl{font-size:10px;font-weight:700;color:var(--err-text);margin-bottom:3px;letter-spacing:.04em;text-transform:uppercase}.rt{font-size:12px;color:#1e293b;line-height:1.6}.footer{position:fixed;bottom:0;left:0;right:0;padding:12px 16px 28px;background:#fff;border-top:1px solid #f1f5f9;z-index:100}.main-btn{width:100%;padding:14px;border-radius:14px;font-size:15px;font-weight:600;cursor:pointer;border:none;outline:none;transition:all .2s;letter-spacing:.4px;-webkit-appearance:none}.main-btn.ready{background:#FF420C;color:#fff;box-shadow:0 4px 14px rgba(255,66,12,.35)}.main-btn.ready:active{transform:scale(.98);background:#e03a0a}.main-btn.submitted{background:#f1f5f9;color:#94a3b8;pointer-events:none}.main-btn.done{background:linear-gradient(135deg,#22c55e,#16a34a);color:#fff;pointer-events:none}.main-btn.rejected{background:#FF420C;color:#fff}.main-btn.rejected:active{transform:scale(.98);background:#e03a0a}.toast{position:fixed;left:50%;bottom:110px;transform:translateX(-50%) scale(.88);background:rgba(15,23,42,.88);color:#f8fafc;padding:9px 18px;border-radius:10px;font-size:13px;white-space:nowrap;z-index:999;opacity:0;pointer-events:none;transition:all .22s}.toast.show{opacity:1;transform:translateX(-50%) scale(1)}</style></head><body><div class=\"state-bar\"><button class=\"sw-btn active\" onclick=\"switchState('idle')\">待提交</button><button class=\"sw-btn\" onclick=\"switchState('submitted')\">已提交</button><button class=\"sw-btn\" onclick=\"switchState('approved')\">审核通过</button><button class=\"sw-btn\" onclick=\"switchState('rejected')\">审核驳回</button></div><div class=\"hero\"><div class=\"hero-bg\"><div class=\"hero-overlay\"></div></div><div class=\"hero-content\"><div class=\"hero-icon\"><svg width=\"26\" height=\"26\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fff\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z\"/><polyline points=\"14 2 14 8 20 8\"/><line x1=\"16\" y1=\"13\" x2=\"8\" y2=\"13\"/><line x1=\"16\" y1=\"17\" x2=\"8\" y2=\"17\"/><polyline points=\"10 9 9 9 8 9\"/></svg></div><div class=\"hero-title\">信息录入</div><div id=\"heroSub\" class=\"hero-sub\">填写右豹账号信息完成实名录入</div></div></div><div class=\"content\"><div class=\"form-card\"><div id=\"statusBanner\"></div><div class=\"sec-label\">账号信息</div><div class=\"field-row\"><div class=\"f-label\">右豹 ID <span class=\"req\">*</span></div><input id=\"fYbId\" class=\"f-input\" type=\"text\" placeholder=\"请输入右豹 ID\"></div><div class=\"field-row\"><div class=\"f-label\">右豹编码 <span class=\"req\">*</span></div><input id=\"fYbCode\" class=\"f-input\" type=\"text\" placeholder=\"请输入右豹编码，如 YB2024001\"></div><div class=\"divider\"></div><div class=\"sec-label\">截图上传</div><div class=\"field-row\"><div class=\"f-label\">右豹 ID 截图 <span class=\"req\">*</span></div><div class=\"upload-area\" id=\"uploadId\" onclick=\"triggerUpload('fileId')\"><span class=\"up-icon\">🖼️</span><span class=\"up-text\">点击上传截图</span><span class=\"up-hint\">支持 JPG / PNG，不超过 10MB</span></div><input type=\"file\" id=\"fileId\" accept=\"image/*\" style=\"display:none\" onchange=\"handleFile(this,'uploadId','previewId')\"></div><div class=\"field-row\"><div class=\"f-label\">右豹编码截图 <span class=\"req\">*</span></div><div class=\"upload-area\" id=\"uploadCode\" onclick=\"triggerUpload('fileCode')\"><span class=\"up-icon\">🖼️</span><span class=\"up-text\">点击上传截图</span><span class=\"up-hint\">支持 JPG / PNG，不超过 10MB</span></div><input type=\"file\" id=\"fileCode\" accept=\"image/*\" style=\"display:none\" onchange=\"handleFile(this,'uploadCode','previewCode')\"></div><div id=\"rejectBlock\"></div></div></div><div class=\"footer\"><button id=\"mainBtn\" class=\"main-btn ready\" onclick=\"handleSubmit()\">提交信息</button></div><div id=\"toast\" class=\"toast\"></div><script>var state='idle';var STATES={idle:{sub:'填写右豹账号信息完成实名录入',banner:null,inputDisabled:false,btnCls:'ready',btnText:'提交信息',reject:null},submitted:{sub:'信息已提交，等待审核中…',banner:{type:'warn',icon:'⏳',title:'审核中，请耐心等待',desc:'您的信息已提交，通常 1-2 个工作日内完成审核'},inputDisabled:true,btnCls:'submitted',btnText:'已提交',reject:null},approved:{sub:'信息录入成功 ✅',banner:{type:'ok',icon:'✅',title:'审核通过',desc:'您的右豹信息已成功录入，可在个人中心查看'},inputDisabled:true,btnCls:'done',btnText:'信息已录入',reject:null},rejected:{sub:'审核未通过，请修改后重新提交',banner:{type:'err',icon:'❌',title:'审核驳回',desc:'您提交的信息未通过审核，请查看驳回原因并重新提交'},inputDisabled:false,btnCls:'rejected',btnText:'提交信息',reject:'上传的右豹 ID 截图不清晰，无法识别有效信息，请重新拍摄后上传。'}};function render(){var c=STATES[state];document.getElementById('heroSub').textContent=c.sub;var b=document.getElementById('statusBanner');b.innerHTML=c.banner?'<div class=\"status-banner '+c.banner.type+'\"><span class=\"bi\">'+c.banner.icon+'</span><div><div class=\"bt '+c.banner.type+'\">'+c.banner.title+'</div><div class=\"bd\">'+c.banner.desc+'</div></div></div>':'';var inputs=document.querySelectorAll('.f-input');inputs.forEach(function(el){el.disabled=c.inputDisabled;el.style.background=c.inputDisabled?'#f8fafc':'#fff';el.style.color=c.inputDisabled?'#94a3b8':'#1e293b'});var btn=document.getElementById('mainBtn');btn.className='main-btn '+c.btnCls;btn.textContent=c.btnText;var rb=document.getElementById('rejectBlock');rb.innerHTML=c.reject?'<div class=\"reject-box\"><div class=\"rl\">驳回原因</div><div class=\"rt\">'+c.reject+'</div></div>':''}function switchState(s){state=s;document.querySelectorAll('.sw-btn').forEach(function(b,i){b.classList.toggle('active',['idle','submitted','approved','rejected'][i]===s)});render()}function handleSubmit(){if(state==='idle'||state==='rejected'){var id=document.getElementById('fYbId').value.trim();var code=document.getElementById('fYbCode').value.trim();if(!id){showToast('请输入右豹 ID');return}if(!code){showToast('请输入右豹编码');return}switchState('submitted');showToast('提交成功，等待审核')}else if(state==='approved'){showToast('信息已录入，无需重复提交')}}function triggerUpload(inputId){if(STATES[state].inputDisabled)return;document.getElementById(inputId).click()}function handleFile(input,areaId,previewId){var file=input.files[0];if(!file)return;var area=document.getElementById(areaId);var reader=new FileReader();reader.onload=function(e){area.innerHTML='<img class=\"preview\" src=\"'+e.target.result+'\"><div class=\"remove-btn\" onclick=\"removeFile(event,\\\"'+areaId+'\\\",\\\"'+input.id+'\\\")\">✕</div>';area.classList.add('has-img')};reader.readAsDataURL(file)}function removeFile(e,areaId,inputId){e.stopPropagation();var area=document.getElementById(areaId);area.innerHTML='<span class=\"up-icon\">🖼️</span><span class=\"up-text\">点击上传截图</span><span class=\"up-hint\">支持 JPG / PNG，不超过 10MB</span>';area.classList.remove('has-img');document.getElementById(inputId).value=''}function showToast(msg){var t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');clearTimeout(t._t);t._t=setTimeout(function(){t.classList.remove('show')},2200)}render();</script></body></html>",
